# Caribou System Unit runtime environment.
#
# Copy to ~/caribou-csu.env on the drone CM5, chmod 0600, then enable csu.service.
# Referenced from /etc/systemd/system/csu.service as EnvironmentFile=.

# Per-drone API key issued by Caribou Hub (Drone Configuration -> API Keys).
# HubLink rejects connections that don't present `bearer.<API_KEY>` in the
# WebSocket subprotocol list. Leave empty for benchtop accept-any mode.
API_KEY=<replace-with-per-drone-api-key>

# Drone identifier (must match the drone record in the Hub).
DRONE_ID=caribou_001

# Optional overrides (uncomment to change defaults):
# MAVLINK_URL=udpin://0.0.0.0:14540
# STREAM_HOST=0.0.0.0
# STREAM_PORT=8765
# UPDATE_RATE_HZ=10
# LEASE_TTL_MS=30000
